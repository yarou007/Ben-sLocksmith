{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.dcemergencylockanddoor.com"
        }
      ],
      "destination": "https://dcemergencylockanddoor.com/:path*",
      "permanent": true
    },
    {
      "source": "/(.*).html",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/index",
      "destination": "/",
      "permanent": true
    }
  ]
}
